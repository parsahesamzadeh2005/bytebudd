# Copy this file to .env and fill in your values
# cp .env.example .env

# ── App ───────────────────────────────────────────────────────────────────
# Set to "production" in production environments
ENVIRONMENT=development

# ── Security (CHANGE THESE IN PRODUCTION) ────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string-here
ENCRYPTION_KEY=change-me-32-char-encryption-key!

# ── Internal Database (ByteBudd's own Postgres) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://bytebudd:bytebudd_secret@postgres:5432/bytebudd
POSTGRES_PASSWORD=bytebudd_secret

# ── Ollama ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:8b
OLLAMA_TIMEOUT=120

# ── CORS (comma-separated list of allowed origins) ────────────────────────
# WARNING: Do NOT use * in production — list your actual frontend origins
CORS_ORIGINS=http://localhost,http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
